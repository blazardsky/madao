{
	"name": "madao",
	"version": "0.2.0",
	"description": "Markdown alternative for easier AI access to your Astro site.",
	"author": "Niccolò Agnoletti",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/blazardsky/madao"
	},
	"keywords": ["astro", "markdown", "ai", "md", "llms.txt", "llm"],
	"type": "module",
	"files": ["dist"],
	"main": "dist/index.js",
	"exports": {
		".": "./dist/index.js",
		"./middleware": "./dist/middleware.js"
	},
	"scripts": {
		"build": "tsc",
		"lint": "biome lint src",
		"format": "biome format src",
		"ci": "biome ci . && pnpm build",
		"prepublishOnly": "pnpm build",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "pnpm version && changeset publish"
	},
	"dependencies": {
		"turndown": "^7.2.4"
	},
	"devDependencies": {
		"@astrojs/ts-plugin": "^1.10.10",
		"@biomejs/biome": "2.5.3",
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@types/node": "^26.1.1",
		"@types/turndown": "^5.0.6",
		"typescript": "^7.0.2"
	},
	"peerDependencies": {
		"astro": "^7.0.7"
	}
}
