{
	"name": "astro-madao",
	"version": "0.3.1",
	"description": "Markdown alternative for easier AI access to your Astro site.",
	"author": "Niccolò Agnoletti",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/blazardsky/madao"
	},
	"keywords": [
		"astro-integration",
		"markdown",
		"ai",
		"llms.txt",
		"utils",
		"utility",
		"seo"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"main": "dist/index.js",
	"exports": {
		".": "./dist/index.js",
		"./middleware": "./dist/middleware.js"
	},
	"scripts": {
		"build": "tsc",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome lint src",
		"format": "biome format src",
		"ci": "biome ci . && pnpm build && pnpm test",
		"prepublishOnly": "pnpm build",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "pnpm build && changeset publish",
		"ship": "bash scripts/ship.sh"
	},
	"dependencies": {
		"turndown": "^7.2.4"
	},
	"devDependencies": {
		"@astrojs/ts-plugin": "^1.10.10",
		"@biomejs/biome": "2.5.3",
		"@changesets/cli": "^2.31.0",
		"@types/node": "^26.1.1",
		"@types/turndown": "^5.0.6",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10"
	},
	"peerDependencies": {
		"astro": "^7.0.7"
	}
}
